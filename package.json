{
    "name": "action-profiler",
    "description": "GitHub Action Profiler",
    "version": "1.0.1",
    "author": "Oguzhan Ozdemir",
    "type": "module",
    "private": true,
    "homepage": "https://github.com/rwxdash/action-profiler",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rwxdash/action-profiler.git"
    },
    "bugs": {
        "url": "https://github.com/rwxdash/action-profiler/issues"
    },
    "keywords": [
        "actions"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "bundle": "npm run format:write && npm run package",
        "format:write": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "local-action": "npx @github/local-action . src/main.ts .env",
        "package": "bash scripts/build.sh && npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
        "package:watch": "npm run package -- --watch"
    },
    "license": "MIT",
    "dependencies": {
        "@actions/artifact": "6.2.1",
        "@actions/core": "3.0.0",
        "@actions/exec": "3.0.0",
        "@actions/github": "9.1.0",
        "@octokit/action": "8.0.4",
        "@octokit/openapi-types": "27.0.0",
        "echarts": "6.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "29.0.2",
        "@rollup/plugin-json": "6.1.0",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@rollup/plugin-typescript": "12.3.0",
        "@types/node": "25.2.0",
        "prettier": "3.8.1",
        "rollup": "4.60.1",
        "typescript": "5.9.3"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.1"
    }
}
