### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# Ignore JSONL files
**/*.jsonl

# Generated from /sys/kernel/btf/vmlinux at build time (kernel-specific)
profiler-ebpf/src/vmlinux.rs
